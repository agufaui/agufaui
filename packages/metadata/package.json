{
  "name": "@agufaui/metadata",
  "version": "0.0.0",
  "description": "Metadata for AgufaUI",
  "author": "Agufa.tech <https://agufa.tech>",
  "license": "MIT",
  "homepage": "https://www.agufaui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agufaui/agufaui.git",
    "directory": "packages/metadata"
  },
  "bugs": {
    "url": "https://github.com/agufaui/agufaui/issues"
  },
  "keywords": [
    "agufa-ui",
    "agufaui",
    "agufa"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.cjs",
      "import": "./index.mjs"
    },
    "./*": "./*"
  },
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "files": [
    "index.*"
  ],
  "scripts": {
    "build": "vite build && nr build:types && cp -t dist/ ./package.json ../../LICENSE",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
    "update": "tsx scripts/update.ts"
  }
}
