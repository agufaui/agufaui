{
  "name": "@agufaui/theme",
  "version": "0.0.1",
  "description": "AgufaUI Theme",
  "author": "Agufa.tech <https://agufa.tech>",
  "license": "MIT",
  "homepage": "https://agufaui.com",
  "repository": {
    "type": "git",
    "url": "git://github.com/agufaui/agufaui",
    "directory": "packages/theme"
  },
  "bugs": {
    "url": "https://github.com/agufaui/agufaui/issues"
  },
  "keywords": [
    "agufa-ui",
    "agufaui",
    "agufa",
    "theme"
  ],
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.mjs",
  "unpkg": "./dist/umd/theme.umd.cjs",
  "jsdelivr": "./dist/umd/theme.umd.cjs",
  "types": "./dist/types/index.d.ts",
  "style": "./dist/es/assets/theme.css",
  "exports": {
    ".": {
      "import": "./dist/es/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/umd/theme.umd.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./theme.css": {
      "import": "./dist/es/assets/theme.css",
      "require": "./dist/es/assets/theme.css"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "watch": "nr build:types && vite build --watch",
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint --ext .ts --ignore-path ../../.eslintignore .",
    "lintfix": "nr lint --fix",
    "typecheck": "tsc --noEmit"
  }
}
