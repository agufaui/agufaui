{
  "name": "@agufaui/vue",
  "version": "0.1.0",
  "description": "Vue UI Components Library",
  "author": "Agufa.tech <https://agufa.tech>",
  "license": "MIT",
  "homepage": "https://agufaui.com",
  "repository": {
    "type": "git",
    "url": "git://github.com/agufaui/agufaui",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/agufaui/agufaui/issues"
  },
  "keywords": [
    "agufa-ui",
    "agufaui",
    "agufa",
    "component library",
    "ui framework",
    "ui",
    "vue",
    "nuxt"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/cjs/vue/index.cjs",
  "module": "./dist/es/vue/index.mjs",
  "unpkg": "./dist/umd/index.js",
  "jsdelivr": "./dist/umd/index.js",
  "types": "./dist/types/vue/index.d.ts",
  "style": "./dist/es/style.css",
  "exports": {
    ".": {
      "import": "./dist/es/vue/index.mjs",
      "require": "./dist/cjs/vue/index.cjs",
      "default": "./dist/umd/index.js",
      "types": "./dist/types/vue/index.d.ts"
    },
    "./style.css": {
      "import": "./dist/es/style.css",
      "require": "./dist/es/style.css"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "watch": "nr build:types && vite build --watch",
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint --ext .ts,.vue --ignore-path ../../.eslintignore .",
    "lintfix": "nr lint --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "vue": "^3.2.37"
  },
  "dependencies": {
    "@agufaui/config": "workspace:^0.0.1",
    "@agufaui/theme": "workspace:^0.0.1",
    "@agufaui/use": "workspace:^0.1.0"
  }
}
